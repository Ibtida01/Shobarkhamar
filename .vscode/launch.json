{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frontend: Open Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npm run dev"],
      "cwd": "${workspaceFolder}/shobarkhamar-complete-frontend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Backend: Docker Compose Up",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "docker compose up -d"],
      "cwd": "${workspaceFolder}/shobarkhamar-complete-backend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Run Full Stack",
      "configurations": [
        "Backend: Docker Compose Up",
        "Frontend: Open Dev Server"
      ]
    }
  ]
}
